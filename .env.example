# Production database for packages/db Prisma schema.
# The legacy local editor store still creates apps/web/data/control3d.sqlite until migration is completed.
DATABASE_URL="postgresql://control3d:control3d@localhost:5432/control3d"

# Uploaded 3D files: apps/web/public/uploads/models

# Required for auth/session signing once Phase 1 auth routes are enabled.
CONTROL3D_AUTH_SECRET="replace-with-at-least-32-random-bytes"

# Optional bootstrap: if the local DB has no admins, the first admin login can create this account.
CONTROL3D_DEFAULT_ADMIN_EMAIL="admin@example.com"
CONTROL3D_DEFAULT_ADMIN_PASSWORD="ChangeMe123"

# Production realtime server. Browser receives this through /api/maps/:id/join-intent.
CONTROL3D_REALTIME_URL="ws://localhost:3005"
CONTROL3D_REALTIME_PORT="3005"
CONTROL3D_REALTIME_SECRET="replace-with-at-least-32-random-bytes"
CONTROL3D_WEB_ORIGIN="http://localhost:3000"
CONTROL3D_ALLOWED_ORIGINS="http://localhost:3000"
CONTROL3D_MAX_CLIENTS_PER_ROOM="50"
CONTROL3D_MAX_PLAYER_SPEED="45"
CONTROL3D_PRESENCE_BROADCAST_HZ="20"

# Dev/debug only. Production must keep realtime as the source of truth.
CONTROL3D_ALLOW_REALTIME_HTTP_FALLBACK="true"
NEXT_PUBLIC_CONTROL3D_ALLOW_REALTIME_FALLBACK="true"
